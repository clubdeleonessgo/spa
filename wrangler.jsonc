{
  "name": "clubdeleonessgo",
  "main": "./worker.js",
  "compatibility_date": "2026-05-29",
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "CERTIFICADOS",
      "id": "f1b965ffea104d589a91cc8e07161624"
    }
  ],
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/certificados", "/certificados/*"]
  }
}
